# -----------------------------------------------------------------------------
# Groww Weekly Review Pulse - Environment Settings Example
# Copy this file to '.env' and fill in your credentials.
# -----------------------------------------------------------------------------

# Groq API Configuration (Required for reasoning / Llama-3.3-70b-versatile)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Google Doc Configuration (The ID of the single running document for Groww)
GROWW_DOC_ID=1_your_google_doc_id_here

# Stakeholder Email Distribution List (Comma-separated emails)
STAKEHOLDER_EMAILS=product@groww.in,support@groww.in,leadership@groww.in

# Environment Configuration (development = creates Gmail draft, production = sends email directly)
NODE_ENV=development

# Analysis configuration (Defaults to 10 weeks)
LOOKBACK_WEEKS=10

# -----------------------------------------------------------------------------
# Optional: Custom MCP server commands (in case you don't want to use standard npx defaults)
# -----------------------------------------------------------------------------
# GDOCS_MCP_COMMAND=npx
# GDOCS_MCP_ARGS=-y,@modelcontextprotocol/server-google-docs
# GMAIL_MCP_COMMAND=npx
# GMAIL_MCP_ARGS=-y,@modelcontextprotocol/server-gmail

# Remote MCP Server URL (SSE transport)
# MCP_SERVER_URL=https://your-mcp-server-domain.com/sse
